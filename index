<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>One Last Swipe 💍</title>
<link href="https://fonts.googleapis.com/css2?family=Circular+Std:wght@400;500;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --tinder-pink: #fe3c72;
    --tinder-orange: #ff6034;
    --tinder-gold: #ffd700;
    --tinder-blue: #2196f3;
    --bg: #f5f5f5;
    --card-radius: 16px;
    --shadow: 0 10px 40px rgba(0,0,0,0.15);
  }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    user-select: none;
  }

  /* ── Header ── */
  header {
    width: 100%;
    max-width: 430px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 8px;
    flex-shrink: 0;
  }
  .logo {
    font-size: 22px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--tinder-pink), var(--tinder-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
  }
  .header-icon {
    font-size: 22px;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s;
  }
  .header-icon:hover { opacity: 1; }

  /* ── Card stack area ── */
  #card-area {
    flex: 1;
    width: 100%;
    max-width: 430px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px 0;
  }

  .card {
    position: absolute;
    width: calc(100% - 32px);
    height: 100%;
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    cursor: grab;
    background: #fff;
    transition: transform 0.05s;
    touch-action: none;
  }
  .card:active { cursor: grabbing; }

  .card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  .card-photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f8b4c8, #ffd6e0);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 80px;
    color: rgba(255,255,255,0.7);
  }

  /* Gradient overlay at bottom */
  .card-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
    padding: 80px 20px 24px;
    color: #fff;
  }

  .card-name-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
  }
  .card-name {
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
  }
  .card-age {
    font-size: 26px;
    font-weight: 400;
  }
  .card-job {
    font-size: 14px;
    font-weight: 600;
    opacity: 0.85;
    margin-bottom: 4px;
  }
  .card-distance {
    font-size: 13px;
    opacity: 0.7;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 8px;
  }
  .card-bio {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.9;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-flirt {
    font-size: 13px;
    opacity: 0.75;
    font-style: italic;
  }
  .card-flirt strong { opacity: 1; font-style: normal; font-weight: 700; }

  /* Swipe stamps */
  .stamp {
    position: absolute;
    top: 40px;
    font-size: 40px;
    font-weight: 900;
    border: 5px solid;
    border-radius: 8px;
    padding: 6px 18px;
    letter-spacing: 3px;
    opacity: 0;
    transition: opacity 0.05s;
    transform: rotate(-20deg);
    text-transform: uppercase;
  }
  .stamp-like {
    left: 24px;
    color: #4caf50;
    border-color: #4caf50;
    transform: rotate(-20deg);
  }
  .stamp-nope {
    right: 24px;
    color: var(--tinder-pink);
    border-color: var(--tinder-pink);
    transform: rotate(20deg);
  }

  /* Behind cards */
  .card-behind {
    transform: scale(0.95) translateY(12px);
    z-index: 0;
    pointer-events: none;
  }
  .card-front { z-index: 1; }

  /* ── Action buttons ── */
  #actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 18px 0 24px;
    flex-shrink: 0;
    width: 100%;
  }

  .btn-action {
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    flex-shrink: 0;
  }
  .btn-action:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(0,0,0,0.22); }
  .btn-action:active { transform: scale(0.95); }

  .btn-nope  { width: 60px; height: 60px; background: #fff; font-size: 28px; }
  .btn-super { width: 50px; height: 50px; background: #fff; font-size: 22px; }
  .btn-like  { width: 60px; height: 60px; background: #fff; font-size: 28px; }

  /* ── Match overlay ── */
  #match-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
  }
  #match-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  .match-title {
    font-size: 48px;
    font-weight: 900;
    background: linear-gradient(135deg, var(--tinder-pink), var(--tinder-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    margin-bottom: 6px;
    animation: matchPop 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  .match-subtitle {
    color: rgba(255,255,255,0.85);
    font-size: 16px;
    margin-bottom: 36px;
    text-align: center;
    animation: matchPop 0.5s 0.1s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  .match-photos {
    display: flex;
    gap: 16px;
    margin-bottom: 36px;
    animation: matchPop 0.5s 0.2s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  .match-photo {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--tinder-pink);
    box-shadow: 0 0 0 4px rgba(254,60,114,0.3);
  }
  .match-photo-placeholder {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f8b4c8, #ffd6e0);
    border: 4px solid var(--tinder-pink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
  }
  .match-name {
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 28px;
    animation: matchPop 0.5s 0.25s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  .btn-match-continue {
    background: linear-gradient(135deg, var(--tinder-pink), var(--tinder-orange));
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 16px 48px;
    font-size: 17px;
    font-weight: 800;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(254,60,114,0.5);
    transition: transform 0.15s;
    animation: matchPop 0.5s 0.3s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  .btn-match-continue:hover { transform: scale(1.04); }
  .btn-match-continue:active { transform: scale(0.97); }

  @keyframes matchPop {
    from { opacity: 0; transform: scale(0.6); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Confetti canvas ── */
  #confetti-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 99;
  }

  /* ── End screen ── */
  #end-screen {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px;
    height: 100%;
    gap: 16px;
  }
  #end-screen .end-emoji { font-size: 72px; }
  #end-screen h2 {
    font-size: 28px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--tinder-pink), var(--tinder-orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  #end-screen p {
    font-size: 16px;
    color: #666;
    max-width: 300px;
    line-height: 1.6;
  }
  #end-screen .match-count {
    font-size: 48px;
    font-weight: 900;
    color: var(--tinder-pink);
  }

  /* ── Upload screen ── */
  #upload-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 40px;
    text-align: center;
    gap: 20px;
  }
  #upload-screen h1 { font-size: 28px; font-weight: 800; color: #333; }
  #upload-screen p { font-size: 15px; color: #888; line-height: 1.6; max-width: 320px; }
  .drop-zone {
    width: 100%;
    max-width: 360px;
    border: 3px dashed #fed1dc;
    border-radius: 20px;
    padding: 40px 20px;
    background: #fff9fa;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--tinder-pink);
    background: #fff0f4;
  }
  .drop-zone-emoji { font-size: 48px; margin-bottom: 12px; }
  .drop-zone p { font-size: 14px; color: #aaa; margin-top: 8px; }
  #file-input { display: none; }
  .btn-primary {
    background: linear-gradient(135deg, var(--tinder-pink), var(--tinder-orange));
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 14px 40px;
    font-size: 16px;
    font-weight: 800;
    font-family: 'Nunito', sans-serif;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(254,60,114,0.4);
    transition: transform 0.15s;
  }
  .btn-primary:hover { transform: scale(1.04); }

  /* ── No json warning ── */
  .warning-box {
    background: #fff8e1;
    border: 1px solid #ffe082;
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 13px;
    color: #7a6300;
    max-width: 360px;
    line-height: 1.5;
    text-align: left;
  }
  .warning-box code {
    background: rgba(0,0,0,0.08);
    padding: 1px 5px;
    border-radius: 4px;
    font-family: monospace;
  }

  /* ── Photo info bar ── */
  .photo-dots {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    display: flex;
    gap: 4px;
    z-index: 2;
  }
  .dot {
    flex: 1;
    height: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.5);
  }
  .dot.active { background: rgba(255,255,255,0.95); }
</style>
</head>
<body>

<canvas id="confetti-canvas"></canvas>

<!-- Upload screen (shown when no photos loaded) -->
<div id="upload-screen">
  <div style="font-size:56px">💍</div>
  <h1>One Last Swipe</h1>
  <p>Drop your <code>profiles.json</code> + photos below, or just the photos to use demo profiles.</p>

  <div class="drop-zone" id="drop-zone">
    <div class="drop-zone-emoji">📂</div>
    <strong style="font-size:15px;color:#555">Drop files here</strong>
    <p>photos + profiles.json</p>
  </div>
  <input type="file" id="file-input" multiple accept="image/*,.json">

  <button class="btn-primary" onclick="document.getElementById('file-input').click()">
    Choose Files
  </button>

  <div class="warning-box">
    📋 <strong>Tip:</strong> Place <code>profiles.json</code> in the same folder as your photos. See the README for format.
    <br>Or just drop photos — sample profiles will be used.
  </div>
</div>

<!-- Main app (hidden until photos loaded) -->
<div id="app" style="display:none;flex-direction:column;align-items:center;width:100%;height:100dvh;">

  <header>
    <div class="header-icon">⚡</div>
    <div class="logo">💍 last swipe</div>
    <div class="header-icon" id="match-counter-icon">❤️ <span id="match-count-header">0</span></div>
  </header>

  <div id="card-area"></div>

  <div id="actions">
    <button class="btn-action btn-nope"  onclick="swipe('left')"  title="Nope">✖️</button>
    <button class="btn-action btn-super" onclick="swipe('super')" title="Super Like">⭐</button>
    <button class="btn-action btn-like"  onclick="swipe('right')" title="Like">💚</button>
  </div>

  <div id="end-screen">
    <div class="end-emoji">🥂</div>
    <h2>You've seen them all!</h2>
    <p>Final match count:</p>
    <div class="match-count" id="final-match-count">0</div>
    <p style="font-size:14px;color:#aaa">Time to celebrate the real one 💍</p>
  </div>
</div>

<!-- Match overlay -->
<div id="match-overlay">
  <div class="match-title">It's a Match!</div>
  <div class="match-subtitle">Someone likes you back 💘</div>
  <div class="match-photos" id="match-photos"></div>
  <div class="match-name" id="match-profile-name"></div>
  <button class="btn-match-continue" onclick="closeMatch()">Keep Swiping</button>
</div>

<script>
// ─────────────────────────────────────────
//  State
// ─────────────────────────────────────────
let profiles = [];
let photoURLs = {}; // filename -> objectURL
let currentIndex = 0;
let matchCount = 0;

// Drag state
let startX = 0, startY = 0, currentX = 0;
let isDragging = false;
let activeCard = null;

// ─────────────────────────────────────────
//  File loading
// ─────────────────────────────────────────
const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');

dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragover'); handleFiles(e.dataTransfer.files); });
fileInput.addEventListener('change', e => handleFiles(e.target.files));

async function handleFiles(files) {
  const arr = Array.from(files);
  const jsonFile = arr.find(f => f.name === 'profiles.json');
  const imageFiles = arr.filter(f => f.type.startsWith('image/'));

  // Load images into objectURLs
  for (const img of imageFiles) {
    photoURLs[img.name] = URL.createObjectURL(img);
  }

  if (jsonFile) {
    const text = await jsonFile.text();
    try {
      profiles = JSON.parse(text);
    } catch(e) {
      alert('Could not parse profiles.json — check the format!');
      return;
    }
  } else if (imageFiles.length > 0) {
    // Auto-generate demo profiles for each image
    const demoNames = ['Alex','Jordan','Sam','Taylor','Casey','Morgan','Riley','Jamie','Avery','Quinn'];
    const demoJobs = ['Chef 👨‍🍳','Pilot ✈️','Vet 🐾','DJ 🎧','Surfer 🏄','Architect 🏛️','Florist 🌸','Baker 🥐'];
    const demoBios = [
      'Here for a good time, not a long time 😎',
      'Professional brunch attender ☕',
      'Dog person. Cat tolerant.',
      'My love language is snacks 🍕',
      'Will cry at your wedding. Guaranteed.',
      'I can fix that. (I cannot fix that.)',
    ];
    const demoFlirts = [
      'compliment my dog','bring wine','dance badly','quote The Office','pretend we\'ve met before'];
    profiles = imageFiles.map((f, i) => ({
      name: demoNames[i % demoNames.length],
      age: 24 + Math.floor(Math.random() * 12),
      job: demoJobs[i % demoJobs.length],
      distance: `${Math.floor(Math.random() * 8) + 1} km away`,
      bio: demoBios[i % demoBios.length],
      flirt: demoFlirts[i % demoFlirts.length],
      photo: f.name,
      forcedMatch: i % 3 === 0
    }));
  } else {
    alert('Please drop at least some photos!');
    return;
  }

  // Shuffle profiles
  profiles = profiles.sort(() => Math.random() - 0.5);

  startApp();
}

function startApp() {
  document.getElementById('upload-screen').style.display = 'none';
  const app = document.getElementById('app');
  app.style.display = 'flex';
  renderCards();
}

// ─────────────────────────────────────────
//  Card rendering
// ─────────────────────────────────────────
function renderCards() {
  const area = document.getElementById('card-area');
  area.innerHTML = '';

  if (currentIndex >= profiles.length) {
    showEndScreen();
    return;
  }

  // Render next card (behind)
  if (currentIndex + 1 < profiles.length) {
    const behind = buildCard(profiles[currentIndex + 1], false);
    behind.classList.add('card-behind');
    area.appendChild(behind);
  }

  // Render current card (front)
  const front = buildCard(profiles[currentIndex], true);
  front.classList.add('card-front');
  area.appendChild(front);
  bindDrag(front);
  activeCard = front;
}

function buildCard(profile, isFront) {
  const card = document.createElement('div');
  card.className = 'card';

  // Photo
  const photoURL = photoURLs[profile.photo];
  if (photoURL) {
    const img = document.createElement('img');
    img.className = 'card-photo';
    img.src = photoURL;
    img.alt = profile.name;
    card.appendChild(img);
  } else {
    const placeholder = document.createElement('div');
    placeholder.className = 'card-photo-placeholder';
    placeholder.innerHTML = '🤷';
    card.appendChild(placeholder);
  }

  // Dots bar
  const dots = document.createElement('div');
  dots.className = 'photo-dots';
  const dot = document.createElement('div');
  dot.className = 'dot active';
  dots.appendChild(dot);
  card.appendChild(dots);

  // Info overlay
  const info = document.createElement('div');
  info.className = 'card-info';
  info.innerHTML = `
    <div class="card-name-line">
      <span class="card-name">${profile.name}</span>
      <span class="card-age">${profile.age}</span>
    </div>
    ${profile.job ? `<div class="card-job">${profile.job}</div>` : ''}
    ${profile.distance ? `<div class="card-distance">📍 ${profile.distance}</div>` : ''}
    ${profile.bio ? `<div class="card-bio">${profile.bio}</div>` : ''}
    ${profile.flirt ? `<div class="card-flirt"><strong>To flirt with me, you should:</strong> ${profile.flirt}</div>` : ''}
  `;
  card.appendChild(info);

  // Stamps
  const like = document.createElement('div');
  like.className = 'stamp stamp-like';
  like.textContent = 'LIKE';
  card.appendChild(like);

  const nope = document.createElement('div');
  nope.className = 'stamp stamp-nope';
  nope.textContent = 'NOPE';
  card.appendChild(nope);

  return card;
}

// ─────────────────────────────────────────
//  Drag / swipe
// ─────────────────────────────────────────
function bindDrag(card) {
  card.addEventListener('mousedown',  onStart);
  card.addEventListener('touchstart', onStart, { passive: true });
}

function onStart(e) {
  isDragging = true;
  const pt = e.touches ? e.touches[0] : e;
  startX = pt.clientX;
  startY = pt.clientY;
  currentX = 0;
  document.addEventListener('mousemove', onMove);
  document.addEventListener('touchmove', onMove, { passive: true });
  document.addEventListener('mouseup',  onEnd);
  document.addEventListener('touchend', onEnd);
}

function onMove(e) {
  if (!isDragging || !activeCard) return;
  const pt = e.touches ? e.touches[0] : e;
  currentX = pt.clientX - startX;
  const currentY = pt.clientY - startY;
  const rotate = currentX * 0.08;
  activeCard.style.transform = `translate(${currentX}px, ${currentY * 0.3}px) rotate(${rotate}deg)`;

  // Stamp visibility
  const like = activeCard.querySelector('.stamp-like');
  const nope = activeCard.querySelector('.stamp-nope');
  const ratio = Math.min(Math.abs(currentX) / 100, 1);
  if (currentX > 20) { like.style.opacity = ratio; nope.style.opacity = 0; }
  else if (currentX < -20) { nope.style.opacity = ratio; like.style.opacity = 0; }
  else { like.style.opacity = 0; nope.style.opacity = 0; }
}

function onEnd() {
  document.removeEventListener('mousemove', onMove);
  document.removeEventListener('touchmove', onMove);
  document.removeEventListener('mouseup', onEnd);
  document.removeEventListener('touchend', onEnd);
  if (!isDragging) return;
  isDragging = false;

  const threshold = 80;
  if (currentX > threshold) swipe('right');
  else if (currentX < -threshold) swipe('left');
  else {
    // Snap back
    if (activeCard) {
      activeCard.style.transition = 'transform 0.4s cubic-bezier(0.34,1.56,0.64,1)';
      activeCard.style.transform = 'translate(0,0) rotate(0deg)';
      activeCard.querySelector('.stamp-like').style.opacity = 0;
      activeCard.querySelector('.stamp-nope').style.opacity = 0;
      setTimeout(() => { if(activeCard) activeCard.style.transition = ''; }, 400);
    }
  }
}

// ─────────────────────────────────────────
//  Swipe logic
// ─────────────────────────────────────────
function swipe(direction) {
  if (!activeCard || currentIndex >= profiles.length) return;
  const profile = profiles[currentIndex];
  const card = activeCard;
  activeCard = null;

  let tx = 0, ty = -80, rotate = 0;
  if (direction === 'right' || direction === 'super') tx = window.innerWidth * 1.3;
  if (direction === 'left') tx = -window.innerWidth * 1.3;
  if (direction === 'right') rotate = 20;
  if (direction === 'left') rotate = -20;

  card.style.transition = 'transform 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.5s';
  card.style.transform = `translate(${tx}px, ${ty}px) rotate(${rotate}deg)`;
  card.style.opacity = '0';

  // Determine match
  const isMatch = direction !== 'left' && (
    profile.forcedMatch === true ||
    (!profile.forcedMatch && Math.random() < 0.35)
  );

  currentIndex++;

  setTimeout(() => {
    card.remove();
    if (isMatch) {
      showMatch(profile);
    } else {
      renderCards();
    }
  }, 480);
}

// ─────────────────────────────────────────
//  Match overlay
// ─────────────────────────────────────────
function showMatch(profile) {
  matchCount++;
  document.getElementById('match-count-header').textContent = matchCount;

  const photosEl = document.getElementById('match-photos');
  photosEl.innerHTML = '';

  // Bride placeholder (left)
  const bride = document.createElement('div');
  bride.className = 'match-photo-placeholder';
  bride.textContent = '👰';
  photosEl.appendChild(bride);

  // Match photo (right)
  const photoURL = photoURLs[profile.photo];
  if (photoURL) {
    const img = document.createElement('img');
    img.className = 'match-photo';
    img.src = photoURL;
    photosEl.appendChild(img);
  } else {
    const ph = document.createElement('div');
    ph.className = 'match-photo-placeholder';
    ph.textContent = '🤩';
    photosEl.appendChild(ph);
  }

  document.getElementById('match-profile-name').textContent = `You & ${profile.name} liked each other!`;

  const overlay = document.getElementById('match-overlay');
  overlay.classList.add('visible');
  launchConfetti();
}

function closeMatch() {
  document.getElementById('match-overlay').classList.remove('visible');
  stopConfetti();
  renderCards();
}

// ─────────────────────────────────────────
//  End screen
// ─────────────────────────────────────────
function showEndScreen() {
  document.getElementById('card-area').style.display = 'none';
  document.getElementById('actions').style.display = 'none';
  const end = document.getElementById('end-screen');
  end.style.display = 'flex';
  document.getElementById('final-match-count').textContent = matchCount;
}

// ─────────────────────────────────────────
//  Confetti
// ─────────────────────────────────────────
const canvas = document.getElementById('confetti-canvas');
const ctx = canvas.getContext('2d');
let confettiParticles = [];
let animFrame = null;
let confettiActive = false;

function launchConfetti() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  confettiParticles = Array.from({ length: 160 }, () => ({
    x: Math.random() * canvas.width,
    y: -20,
    r: Math.random() * 8 + 4,
    color: ['#fe3c72','#ff6034','#ffd700','#4caf50','#2196f3','#e91e63','#ff9800'][Math.floor(Math.random()*7)],
    vx: (Math.random() - 0.5) * 6,
    vy: Math.random() * 4 + 2,
    spin: (Math.random() - 0.5) * 0.3,
    angle: Math.random() * Math.PI * 2,
    shape: Math.random() > 0.5 ? 'rect' : 'circle',
  }));
  confettiActive = true;
  animateConfetti();
}

function animateConfetti() {
  if (!confettiActive) return;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  confettiParticles.forEach(p => {
    p.x += p.vx; p.y += p.vy; p.angle += p.spin;
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.angle);
    ctx.fillStyle = p.color;
    if (p.shape === 'rect') ctx.fillRect(-p.r, -p.r/2, p.r*2, p.r);
    else { ctx.beginPath(); ctx.arc(0, 0, p.r/2, 0, Math.PI*2); ctx.fill(); }
    ctx.restore();
  });
  confettiParticles = confettiParticles.filter(p => p.y < canvas.height + 20);
  if (confettiParticles.length > 0) animFrame = requestAnimationFrame(animateConfetti);
  else stopConfetti();
}

function stopConfetti() {
  confettiActive = false;
  if (animFrame) cancelAnimationFrame(animFrame);
  ctx.clearRect(0, 0, canvas.width, canvas.height);
}
</script>
